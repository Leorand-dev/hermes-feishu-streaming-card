+
+    async def _send_stream_card(
+        self,
+        *,
+        chat_id: str,
+        content: str,
+        reply_to: Optional[str] = None,
+        metadata: Optional[Dict[str, Any]] = None,
+    ) -> SendResult:
+        """Send the initial interactive card for a streaming response."""
+        payload = self._build_stream_card_content(content, status="thinking")
+        logger.info("[Feishu] _send_stream_card: sending card msg_type=interactive, content_len=%s", len(payload))
+        try:
+            response = await self._feishu_send_with_retry(
+                chat_id=chat_id,
+                msg_type="interactive",
+                payload=payload,
+                reply_to=reply_to,
+                metadata=metadata,
+            )
+            result = self._finalize_send_result(response, "stream_card send failed")
+            logger.info("[Feishu] _send_stream_card result: success=%s message_id=%s",
+                        result.success, result.message_id)
+            if not result.success:
+                logger.warning("[Feishu] _send_stream_card failed: %s", result.error)
+                # Try to log the raw response for debugging
+                raw = getattr(result, "raw_response", None)
+                if raw is not None:
+                    logger.warning("[Feishu] _send_stream_card raw_response: code=%s msg=%s",
+                                   getattr(raw, "code", "?"), getattr(raw, "msg", "?"))
+            return result
+        except Exception as exc:
+            logger.error("[Feishu] Failed to send stream card: %s", exc, exc_info=True)
+            return SendResult(success=False, error=str(exc))
+
+    async def _edit_stream_card(
+        self,
+        *,
+        message_id: str,
+        content: str,
+        finalize: bool = False,
+    ) -> SendResult:
+        """Incremental update of a streaming card body.
+
+        Instead of rebuilding the entire card from scratch on every edit,
+        this method tracks the number of characters already committed and
+        only processes the *delta* — the new text since the last update.
+        Each delta is ``format_message``-ed once and appended as a new
+        markdown element, so the card grows element by element and total
+        processing cost is O(N) rather than O(N²).
+        """
+        # Retrieve or initialise incremental state for this message.
+        elements = self._stream_card_parts.get(message_id)
+        if elements is None:
+            # First edit on this message — initialise with an empty list
+            # and let the delta capture the full content.
+            elements = []
+            self._stream_card_parts[message_id] = elements
+            self._stream_card_chars[message_id] = 0
+
+        sent_chars = self._stream_card_chars.get(message_id, 0)
+        delta = content[sent_chars:] if len(content) > sent_chars else ""
+
+        if delta:
+            formatted_delta = self.format_message(delta)
+            if formatted_delta.strip():
+                elements.append({"tag": "markdown", "content": formatted_delta})
+                self._stream_card_chars[message_id] = len(content)
+
+        try:
+            status = "done" if finalize else "streaming"
+            payload = self._build_stream_card_from_elements(elements, status=status)
+            token = await self._run_blocking(self._fetch_feishu_token)
+            if not token:
+                logger.warning("[Feishu] _edit_stream_card: no token, skipping card edit")
+                return SendResult(success=False, error="no Feishu token")
+            url = f"https://open.feishu.cn/open-apis/im/v1/messages/{message_id}"
+            headers = {
+                "Content-Type": "application/json",
+                "Authorization": f"Bearer {token}",
+            }
+            body_data = json.dumps({"content": payload}, ensure_ascii=False)
+
+            resp = await self._run_blocking(
+                lambda: self._http_patch(url, headers=headers, body=body_data),
+            )
+            code = resp.get("code", -1) if isinstance(resp, dict) else -1
+            if code == 0:
+                logger.info("[Feishu] _edit_stream_card ok: msg_id=%s final=%s parts=%s",
+                            message_id, finalize, len(elements))
+                if finalize:
+                    # Free per-message state — card is done, no more edits
+                    self._card_stream_messages.discard(message_id)
+                    self._stream_card_parts.pop(message_id, None)
+                    self._stream_card_chars.pop(message_id, None)
+                return SendResult(success=True, message_id=message_id)
+            else:
+                msg = resp.get("msg", "unknown") if isinstance(resp, dict) else str(resp)
+                logger.warning("[Feishu] _edit_stream_card failed: code=%s msg=%s", code, msg)
+                return SendResult(success=False, error=f"card update failed: {msg}")
+        except Exception as exc:
+            logger.error("[Feishu] _edit_stream_card error %s: %s", message_id, exc, exc_info=True)
+            return SendResult(success=False, error=str(exc))
+
