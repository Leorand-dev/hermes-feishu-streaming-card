+
+    @staticmethod
+    def _build_stream_card_content(text: str, status: str = "streaming") -> str:
+        """Build a Feishu interactive card JSON for streaming messages.
+
+        Args:
+            text: The message content (markdown)
+            status: One of "thinking", "streaming", "done"
+
+        Returns:
+            JSON string suitable for Feishu interactive card msg_type
+        """
+        header_map = {
+            "thinking": "🤖 Hermes 思考中...",
+            "streaming": "🤖 Hermes",
+            "done": "🤖 Hermes",
+        }
+        header_text = header_map.get(status, "🤖 Hermes")
+        card = {
+            "config": {"wide_screen_mode": True},
+            "header": {
+                "title": {"tag": "plain_text", "content": header_text},
+                "template": "blue",
+            },
+            "elements": [
+                {"tag": "markdown", "content": text},
+            ],
+        }
+        return json.dumps(card, ensure_ascii=False)
+
+    async def _edit_stream_card(
+        self,
+        *,
+        message_id: str,
+        content: str,
+        finalize: bool = False,
+    ) -> SendResult:
+        """Update the markdown body of a streaming card via raw HTTP PATCH.
+
+        Uses direct HTTP instead of the lark_oapi SDK because the SDK's
+        UpdateMessageRequestBody builder fails field validation for
+        interactive cards.
+        """
+        try:
+            access_token = self._fetch_feishu_token()
+            url = f"https://open.feishu.cn/open-apis/im/v1/messages/{message_id}"
+            body_data = json.dumps({"content": self._build_stream_card_content(
+                content, status="done" if finalize else "streaming")})
+            headers = {
+                "Authorization": f"Bearer {access_token}",
+                "Content-Type": "application/json; charset=utf-8",
+            }
+            resp = await self._run_blocking(
+                lambda: self._http_patch(url, headers=headers, body=body_data),
+            )
+            if resp.get("code") == 0:
+                logger.info("[Feishu] Card updated successfully for %s (finalize=%s)", message_id, finalize)
+                return SendResult(success=True, message_id=message_id)
+            else:
+                error_msg = resp.get("msg", "unknown error")
+                logger.warning("[Feishu] Card update failed for %s: %s", message_id, error_msg)
+                return SendResult(success=False, error=f"Card update failed: {error_msg}")
+        except Exception as exc:
+            logger.error("[Feishu] _edit_stream_card error %s: %s", message_id, exc)
+            return SendResult(success=False, error=str(exc))
+
+    @staticmethod
+    def _split_stream_chunks(text: str, max_chunks: int = 4) -> list:
+        """Split text into cumulative progressive chunks for streaming card updates.
+
+        Returns a list of strings where each chunk is a prefix of the full text.
+        Short messages (<150 chars) return [text] — no split.
+        The last chunk is always the full text.
+        """
+        if len(text) < 150:
+            return [text]
+
+        total_len = len(text)
+        positions = []
+        for i in range(1, max_chunks + 1):
+            target_pos = int(total_len * i / max_chunks)
+            if i < max_chunks:
+                # Try to break at a paragraph boundary for cleaner updates
+                window_start = max(0, target_pos - 60)
+                nl2_pos = text.rfind('\n\n', window_start, target_pos)
+                if nl2_pos > 0:
+                    target_pos = nl2_pos + 2  # include the \n\n
+                else:
+                    nl_pos = text.rfind('\n', window_start, target_pos)
+                    if nl_pos > 0:
+                        target_pos = nl_pos + 1  # include the \n
+            positions.append(target_pos)
+
+        chunks = []
+        for pos in positions:
+            chunks.append(text[:pos])
+
+        # Deduplicate consecutive identical chunks
+        deduped = [chunks[0]]
+        for c in chunks[1:]:
+            if c != deduped[-1]:
+                deduped.append(c)
+
+        deduped[-1] = text  # last chunk is always the full text
+        return deduped
