+    # -----------------------------------------------------------------------
+    # Streaming card — interactive card that is progressively updated during
+    # LLM streaming.  Enabled when send() / edit_message() receive
+    # ``stream_card: True`` in metadata.
+    # -----------------------------------------------------------------------
+
+    STREAM_CARD_HEADERS = {
+        "thinking": "🤖 Hermes 思考中...",
+        "streaming": "🤖 Hermes",
+        "done": "🤖 Hermes",
+    }
+    STREAM_CARD_TEMPLATES = {
+        "thinking": "blue",
+        "streaming": "blue",
+        "done": "blue",
+    }
+
+    @staticmethod
+    def _build_stream_card_content(text: str, *, status: str = "streaming") -> str:
+        """Build an interactive card payload for streaming conversation.
+
+        The card uses a header + markdown-body layout that can be
+        progressively updated via :meth:`edit_message` as the agent
+        generates its response.
+
+        *status* controls the header text and template colour:
+        ``"thinking"`` / ``"streaming"`` / ``"done"``.
+        """
+        title = FeishuAdapter.STREAM_CARD_HEADERS.get(status, "🤖 Hermes")
+        template = FeishuAdapter.STREAM_CARD_TEMPLATES.get(status, "blue")
+        card = {
+            "config": {"wide_screen_mode": True},
+            "header": {
+                "title": {"tag": "plain_text", "content": title},
+                "template": template,
+            },
+            "elements": [
+                {"tag": "markdown", "content": text or ""},
+            ],
+        }
+        return json.dumps(card, ensure_ascii=False)
+
+    @staticmethod
+    def _build_stream_card_from_elements(elements: "List[Dict[str, Any]]", *, status: str = "streaming") -> str:
+        """Build a streaming card JSON from a list of pre-built card elements.
+
+        Each element is a full card element dict (e.g. ``{"tag": "markdown", "content": "..."}``).
+        Used by the incremental update path where new content is appended as
+        an additional markdown element rather than replacing the entire body.
+        """
+        title = FeishuAdapter.STREAM_CARD_HEADERS.get(status, "🤖 Hermes")
+        template = FeishuAdapter.STREAM_CARD_TEMPLATES.get(status, "blue")
+        card = {
+            "config": {"wide_screen_mode": True},
+            "header": {
+                "title": {"tag": "plain_text", "content": title},
+                "template": template,
+            },
+            "elements": elements if elements else [{"tag": "markdown", "content": "..."}],
+        }
+        return json.dumps(card, ensure_ascii=False)
+
