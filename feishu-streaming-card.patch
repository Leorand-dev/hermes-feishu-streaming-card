+    def _fetch_feishu_token(self) -> Optional[str]:
+        """Fetch a tenant access token via direct HTTP call.
+
+        Used by :meth:`_edit_stream_card` to bypass lark_oapi SDK validation
+        issues with interactive card updates.  Falls back to ``httpx`` if
+        available, otherwise ``urllib.request``.
+        """
+        import json as _json
+        _data = _json.dumps({
+            "app_id": self._app_id,
+            "app_secret": self._app_secret,
+        }).encode("utf-8")
+        try:
+            import httpx
+            r = httpx.post(
+                "https://open.feishu.cn/open-apis/auth/v3/tenant_access_token/internal",
+                content=_data,
+                headers={"Content-Type": "application/json"},
+                timeout=10,
+            )
+            return r.json().get("tenant_access_token")
+        except ImportError:
+            from urllib.request import Request, urlopen
+            req = Request(
+                "https://open.feishu.cn/open-apis/auth/v3/tenant_access_token/internal",
+                data=_data,
+                headers={"Content-Type": "application/json"},
+            )
+            with urlopen(req, timeout=10) as resp:
+                return _json.loads(resp.read().decode("utf-8")).get("tenant_access_token")
+        except Exception as exc:
+            logger.error("[Feishu] _fetch_feishu_token failed: %s", exc)
+            return None
+
+    @staticmethod
+    def _http_patch(url: str, headers: dict, body: str) -> Any:
+        """Make an HTTP PATCH request and return a response-lik eobject.
+
+        Used by :meth:`_edit_stream_card` to update interactive card content
+        via raw HTTP instead of the lark_oapi SDK.
+        """
+        import json as _json
+        try:
+            import httpx
+            r = httpx.patch(url, headers=headers, content=body, timeout=10)
+            return _json.loads(r.text)
+        except ImportError:
+            from urllib.request import Request, urlopen
+            req = Request(url, data=body.encode("utf-8"), headers=headers, method="PATCH")
+            with urlopen(req, timeout=10) as resp:
+                return _json.loads(resp.read().decode("utf-8"))
+        except Exception as exc:
+            return {"code": -1, "msg": str(exc)}
+
