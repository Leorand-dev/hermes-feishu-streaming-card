+    @staticmethod
+    def _fetch_feishu_token(app_id: str = None, app_secret: str = None) -> str:
+        """Get a Feishu tenant access token via HTTP POST."""
+        import urllib.request, urllib.parse
+        if not app_id or not app_secret:
+            app_id = os.getenv("FEISHU_APP_ID", "")
+            app_secret = os.getenv("FEISHU_APP_SECRET", "")
+        data = json.dumps({
+            "app_id": app_id,
+            "app_secret": app_secret,
+        }).encode("utf-8")
+        req = urllib.request.Request(
+            "https://open.feishu.cn/open-apis/auth/v3/tenant_access_token/internal",
+            data=data,
+            headers={"Content-Type": "application/json; charset=utf-8"},
+            method="POST",
+        )
+        with urllib.request.urlopen(req, timeout=10) as resp:
+            result = json.loads(resp.read().decode("utf-8"))
+        return result.get("tenant_access_token", "")
+
+    @staticmethod
+    def _http_patch(url: str, headers: dict, body: str) -> dict:
+        """Make an HTTP PATCH request and return the JSON response."""
+        import urllib.request
+        data = body.encode("utf-8") if isinstance(body, str) else body
+        req = urllib.request.Request(
+            url, data=data, headers=headers, method="PATCH",
+        )
+        with urllib.request.urlopen(req, timeout=15) as resp:
+            return json.loads(resp.read().decode("utf-8"))
+
+        if "UpdateMessageRequest" in globals():
+            return (
+                UpdateMessageRequest.builder()
+                .message_id(message_id)
+                .request_body(request_body)
+                .build()
+            )
+        return SimpleNamespace(message_id=message_id, request_body=request_body)
